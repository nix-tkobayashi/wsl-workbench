{
  "name": "wsl-workbench",
  "version": "0.9.0",
  "description": "Lightweight WSL file tree, editor, and terminal workbench for AI CLIs",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/",
    "dist": "electron-builder --win nsis portable",
    "dist:zip": "electron-builder --win zip",
    "audit": "npm audit",
    "clean": "node -e \"require('fs').rmSync('node_modules',{recursive:true,force:true}); require('fs').rmSync('package-lock.json',{force:true})\""
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.wslworkbench.app",
    "productName": "WSL Workbench",
    "npmRebuild": false,
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "fileAssociations": [
      {
        "ext": "wslwb-workspace",
        "name": "WSL Workbench Workspace",
        "description": "WSL Workbench workspace file",
        "role": "Editor",
        "icon": "build/icon.ico"
      }
    ]
  }
}
